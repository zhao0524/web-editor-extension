{
  "manifest_version": 3,
  "name": "H1 Changer",
  "version": "1.0",
  "description": "Changes all H1 headings on the current page to Hello World.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "H1 Changer"
  }
}
